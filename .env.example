# Bu dosyayı .env.local olarak kopyala ve kendi Supabase proje değerlerini gir.
# Değerler: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Film modülü (isteğe bağlı — tanımlı değilse elle ekleme çalışır)
# TMDB: themoviedb.org -> Ayarlar -> API -> "API Read Access Token" (uzun eyJ... değeri)
VITE_TMDB_TOKEN=
# OMDb (gerçek IMDb puanı için): omdbapi.com/apikey.aspx -> ücretsiz anahtar
VITE_OMDB_KEY=4bf52b74
